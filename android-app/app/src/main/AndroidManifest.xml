<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml — AI Android Assistant
    Declares all permissions, the main activity, and the foreground VoiceService.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- =====================================================================
         Permissions
         ===================================================================== -->

    <!-- Microphone access for real-time voice capture -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Phone call execution -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!-- Reading contacts for name→number resolution -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Media / gallery access -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!-- Flashlight / torch control via CameraManager.setTorchMode() -->
    <!-- FLASHLIGHT is a normal permission — granted automatically, no runtime request needed -->
    <uses-permission android:name="android.permission.FLASHLIGHT" />

    <!-- Speakerphone control via AudioManager -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Media access on Android 13+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- Haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Alarm creation via AlarmClock intent -->
    <uses-permission android:name="android.permission.SET_ALARM" />

    <!-- Foreground service (needed for VoiceService) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Network access to reach local AI engine -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Required hardware -->
    <uses-feature android:name="android.hardware.microphone" android:required="true" />

    <!-- =====================================================================
         Package Visibility (Android 11+)
         Required so getLaunchIntentForPackage() can find installed apps.
         Without this, the system hides all other apps from our queries.
         ===================================================================== -->
    <queries>
        <!-- Common apps used in demo commands -->
        <package android:name="com.google.android.youtube" />
        <package android:name="com.whatsapp" />
        <package android:name="com.instagram.android" />
        <package android:name="com.android.chrome" />
        <package android:name="com.google.android.apps.maps" />
        <package android:name="com.android.settings" />
        <package android:name="com.spotify.music" />
        <package android:name="com.google.android.gm" />
        <package android:name="com.google.android.apps.photos" />
        <package android:name="com.google.android.dialer" />
        <package android:name="com.google.android.apps.messaging" />
        <package android:name="com.google.android.calculator" />
        <package android:name="com.google.android.deskclock" />
        <package android:name="com.google.android.calendar" />
        <package android:name="com.google.android.apps.docs" />
        <package android:name="com.twitter.android" />
        <package android:name="com.facebook.katana" />
        <package android:name="org.telegram.messenger" />
        <package android:name="us.zoom.videomeetings" />
        <package android:name="com.netflix.mediaclient" />
        <package android:name="com.google.android.apps.nbu.paisa.user" />
        <package android:name="com.phonepe.app" />
        <package android:name="net.one97.paytm" />
        <package android:name="com.flipkart.android" />
        <package android:name="com.application.zomato" />
        <package android:name="in.swiggy.android" />
    </queries>

    <!-- =====================================================================
         Application
         ===================================================================== -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AIAssistant"
        android:usesCleartextTraffic="true">
        <!--
            usesCleartextTraffic="true" is required so the app can reach the
            AI engine over plain HTTP on the local network during development.
            Remove or restrict this for production builds.
        -->

        <!-- Main UI Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".BackendActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Foreground service that drives continuous voice capture -->
        <service
            android:name=".VoiceService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- FileProvider — required to share photo files with WhatsApp securely -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.aiassistant.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Accessibility service — auto-taps the WhatsApp Send button after photo share -->
        <service
            android:name=".AutoSendAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/auto_send_accessibility_service" />
        </service>

    </application>

</manifest>
