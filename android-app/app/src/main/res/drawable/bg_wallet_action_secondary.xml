<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#4E6387"
                android:endColor="#344B70" />
            <corners android:radius="31dp" />
            <stroke
                android:width="1dp"
                android:color="#8EAED7" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#3C4E70"
                android:endColor="#273754" />
            <corners android:radius="31dp" />
            <stroke
                android:width="1dp"
                android:color="#6F8DB5" />
        </shape>
    </item>
</selector>
