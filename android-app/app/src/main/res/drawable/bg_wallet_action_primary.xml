<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#7FBFFF"
                android:centerColor="#4B95E8"
                android:endColor="#2E6FCE" />
            <corners android:radius="31dp" />
            <stroke
                android:width="1dp"
                android:color="#BFE3FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#70B4F8"
                android:centerColor="#4289DC"
                android:endColor="#2B67BE" />
            <corners android:radius="31dp" />
            <stroke
                android:width="1dp"
                android:color="#A9D6F7" />
        </shape>
    </item>
</selector>
