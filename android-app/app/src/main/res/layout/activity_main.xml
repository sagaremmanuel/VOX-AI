<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootHome"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ScrollView
            android:id="@+id/voiceScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:paddingStart="14dp"
            android:paddingTop="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/contentShell"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_wallet_shell"
                android:orientation="vertical"
                android:padding="14dp">

                <FrameLayout
                    android:id="@+id/topCard"
                    android:layout_width="match_parent"
                    android:layout_height="312dp"
                    android:background="@drawable/bg_wallet_top_card"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_wallet_avatar_user" />

                        <TextView
                            style="@style/TextVoxTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="Vox"
                            android:textColor="#DDEBFF"
                            android:textSize="23sp" />

                        <ImageButton
                            android:id="@+id/btnMenu"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_wallet_round_button"
                            android:contentDescription="Menu"
                            android:padding="8dp"
                            android:src="@drawable/ic_menu_hamburger"
                            android:tint="#EAF5FF" />
                    </LinearLayout>

                    <TextView
                        style="@style/TextVoxCaption"
                        android:id="@+id/tvModeHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|center_horizontal"
                        android:layout_marginTop="60dp"
                        android:background="@drawable/bg_wallet_chip"
                        android:paddingStart="16dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="8dp"
                        android:text="Voice mode listens for commands."
                        android:textColor="#D6E7FF"
                        android:textSize="12sp" />

                    <TextView
                        style="@style/TextVoxDisplay"
                        android:id="@+id/tvTranscript"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="116dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="2"
                        android:text="Waiting for speech..."
                        android:textColor="#F2F8FF"
                        android:textSize="30sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="-28dp"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:id="@+id/avatarContainer"
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_wallet_avatar_ringed"
                            android:padding="8dp">

                            <View
                                android:id="@+id/vAvatarGlow"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_wallet_avatar_green" />

                            <View
                                android:id="@+id/vAmbientRing"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_wallet_avatar_soft_ring" />

                            <View
                                android:id="@+id/vAmbientCore"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:background="@drawable/bg_wallet_avatar_dot" />
                        </FrameLayout>

                        <View
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_wallet_avatar_yellow" />

                        <View
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_wallet_avatar_pink" />

                        <View
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_wallet_avatar_orange" />

                        <View
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:background="@drawable/bg_wallet_avatar_blue" />
                    </LinearLayout>
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/interactionCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="38dp"
                    android:background="@drawable/bg_wallet_transaction_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextVoxCaption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last interaction"
                        android:textColor="#AFC4E8"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_wallet_avatar_ringed" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/TextVoxTitle"
                                android:id="@+id/tvStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Status: Idle"
                                android:textColor="#E9F3FF"
                                android:textSize="19sp" />

                            <TextView
                                style="@style/TextVoxCaption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Recent activity"
                                android:textColor="#9CB2D9"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/chatPanel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_chat_surface"
            android:orientation="vertical"
            android:padding="14dp"
            android:visibility="gone">

            <TextView
                style="@style/TextVoxTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat"
                android:textColor="#EAF3FF"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvThinkingIndicator"
                style="@style/TextVoxCaption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Thinking..."
                android:textColor="#BFD3F0"
                android:textSize="12sp"
                android:visibility="gone" />

            <ScrollView
                android:id="@+id/scrollChatHistory"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="10dp"
                android:fadeScrollbars="false"
                android:scrollbars="vertical">

                <LinearLayout
                    android:id="@+id/chatMessagesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    style="@style/WidgetVoxInput"
                    android:id="@+id/etChatInput"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chat_input"
                    android:hint="Message Vox"
                    android:imeOptions="actionSend"
                    android:inputType="textCapSentences"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="#EAF2FF"
                    android:textColorHint="#B5C7E6"
                    android:textSize="15sp" />

                <Button
                    style="@style/WidgetVoxButton"
                    android:id="@+id/btnChatSend"
                    android:layout_width="70dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_wallet_action_primary"
                    android:text="Send"
                    android:textColor="#EBF7FF" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottomTray"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="14dp"
            android:orientation="horizontal"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <Button
                style="@style/WidgetVoxButton"
                android:id="@+id/btnChatMode"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="@drawable/bg_wallet_action_secondary"
                android:elevation="8dp"
                android:text="Chat Mode"
                android:textColor="#DDEBFF" />

            <Button
                style="@style/WidgetVoxButton"
                android:id="@+id/btnMic"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_wallet_action_primary"
                android:elevation="8dp"
                android:text="Start Voice"
                android:textColor="#EEF8FF" />
        </LinearLayout>

        <Button
            android:id="@+id/btnVoiceMode"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sideDrawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@drawable/bg_wallet_side_drawer"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="44dp"
        android:paddingEnd="18dp"
        android:paddingBottom="24dp">

        <TextView
            style="@style/TextVoxTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Navigation"
            android:textColor="#EAF4FF"
            android:textSize="22sp" />

        <TextView
            style="@style/TextVoxCaption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Vox assistant"
            android:textColor="#9BB3D9"
            android:textSize="13sp" />

        <TextView
            style="@style/TextVoxCaption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Themes"
            android:textColor="#BFD0EA"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnThemeOcean"
                style="@style/WidgetVoxButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_wallet_action_secondary"
                android:text="Ocean"
                android:textColor="#E6F2FF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnThemeMidnight"
                style="@style/WidgetVoxButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_wallet_action_secondary"
                android:text="Midnight"
                android:textColor="#E6F2FF"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnThemeAurora"
                style="@style/WidgetVoxButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_wallet_action_secondary"
                android:text="Aurora"
                android:textColor="#E6F2FF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnThemeGraphite"
                style="@style/WidgetVoxButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_wallet_action_secondary"
                android:text="Graphite"
                android:textColor="#E6F2FF"
                android:textSize="12sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnThemeSunset"
            style="@style/WidgetVoxButton"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_wallet_action_secondary"
            android:text="Sunset"
            android:textColor="#E6F2FF"
            android:textSize="12sp" />

        <Button
            style="@style/WidgetVoxButton"
            android:id="@+id/btnBackend"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_wallet_action_secondary"
            android:text="Backend"
            android:textColor="#E6F2FF"
            android:textSize="15sp" />

        <TextView
            style="@style/TextVoxBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Use Chat Mode for typed conversation and Start Voice for hands-free control."
            android:textColor="#93ACD4"
            android:textSize="13sp" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
