<?xml version="1.0" encoding="utf-8"?>
<!--
    Accessibility service configuration for AutoSendAccessibilityService.
    - No packageNames filter: handles both com.whatsapp (share) and any camera app (shutter)
    - Listens for window content changes to detect buttons
    - canRetrieveWindowContent is required to traverse the view hierarchy
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagRetrieveInteractiveWindows"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_service_description"
    android:settingsActivity="com.aiassistant.MainActivity" />
